{
  "name": "contentful-slideout",
  "version": "1.0.2",
  "description": "A powerful, flexible React component that brings Contentful's live preview experience to any Next.js application",
  "keywords": [
    "react",
    "nextjs",
    "contentful",
    "slideout",
    "preview",
    "cms",
    "content-management",
    "typescript",
    "tailwind"
  ],
  "author": "CrashBytes",
  "license": "MIT",
  "homepage": "https://github.com/CrashBytes/contentful-slideout#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/CrashBytes/contentful-slideout.git"
  },
  "bugs": {
    "url": "https://github.com/CrashBytes/contentful-slideout/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./previews": {
      "import": "./dist/previews.esm.js",
      "require": "./dist/previews.js",
      "types": "./dist/previews.d.ts"
    },
    "./live-updates": {
      "import": "./dist/live-updates.esm.js",
      "require": "./dist/live-updates.js",
      "types": "./dist/live-updates.d.ts"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:lib": "rollup -c rollup.config.js",
    "start": "next start",
    "test": "jest --no-coverage",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "analyze": "ANALYZE=true npm run build",
    "validate": "npm run type-check && npm run lint && npm run format:check && npm run test",
    "fix-storybook": "node scripts/fix-storybook.js",
    "fix-storybook:auto": "node scripts/fix-storybook.js --auto-fix",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static",
    "storybook:test": "test-storybook",
    "storybook:chromatic": "npx chromatic --project-token=$CHROMATIC_PROJECT_TOKEN",
    "prepublishOnly": "npm run validate && npm run build:lib",
    "publish:patch": "npm version patch && npm publish",
    "publish:minor": "npm version minor && npm publish",
    "publish:major": "npm version major && npm publish"
  },
  "peerDependencies": {
    "date-fns": ">=4.0.0",
    "lucide-react": ">=0.200.0",
    "next": ">=14.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": false
    }
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "immer": "^11.1.4",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.6",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "^10.2.13",
    "@storybook/addon-onboarding": "^10.2.13",
    "@storybook/addon-viewport": "^9.0.8",
    "@storybook/blocks": "^8.6.14",
    "@storybook/nextjs": "^10.2.13",
    "@storybook/react": "^10.2.13",
    "@storybook/test": "^8.6.15",
    "@storybook/test-runner": "^0.24.2",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "contentful": "^11.10.5",
    "date-fns": "^4.1.0",
    "eslint": "^10.0.2",
    "eslint-config-next": "^16.1.6",
    "framer-motion": "^12.34.3",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lucide-react": "^0.575.0",
    "next": "^16.1.6",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rollup": "^4.59.0",
    "rollup-plugin-dts": "^6.3.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "storybook": "^10.2.13",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/yourusername"
  }
}
