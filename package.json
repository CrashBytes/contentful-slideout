{
  "name": "contentful-slideout",
  "version": "1.1.3",
  "description": "A powerful, flexible React component that brings Contentful's live preview experience to any Next.js application",
  "keywords": [
    "react",
    "nextjs",
    "contentful",
    "slideout",
    "preview",
    "cms",
    "content-management",
    "typescript",
    "tailwind"
  ],
  "author": "CrashBytes",
  "license": "MIT",
  "homepage": "https://github.com/CrashBytes/contentful-slideout#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/CrashBytes/contentful-slideout.git"
  },
  "bugs": {
    "url": "https://github.com/CrashBytes/contentful-slideout/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./previews": {
      "import": "./dist/previews.esm.js",
      "require": "./dist/previews.js",
      "types": "./dist/previews.d.ts"
    },
    "./live-updates": {
      "import": "./dist/live-updates.esm.js",
      "require": "./dist/live-updates.js",
      "types": "./dist/live-updates.d.ts"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:lib": "rollup -c rollup.config.js",
    "start": "next start",
    "test": "jest --no-coverage",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "npx eslint src",
    "lint:fix": "npx eslint src --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "analyze": "ANALYZE=true npm run build",
    "validate": "npm run type-check && npm run lint && npm run format:check && npm run test",
    "fix-storybook": "node scripts/fix-storybook.js",
    "fix-storybook:auto": "node scripts/fix-storybook.js --auto-fix",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static",
    "storybook:test": "test-storybook",
    "storybook:chromatic": "npx chromatic --project-token=$CHROMATIC_PROJECT_TOKEN",
    "prepublishOnly": "npm run validate && npm run build:lib"
  },
  "peerDependencies": {
    "date-fns": ">=4.0.0",
    "lucide-react": ">=0.200.0 || ^1.14.0",
    "next": ">=14.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": false
    }
  },
  "overrides": {
    "@babel/plugin-transform-modules-systemjs": "^7.29.4",
    "fast-uri": "^3.1.2",
    "esbuild": "^0.28.1",
    "form-data": "^4.0.6",
    "ws": "^8.21.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "immer": "^11.1.8",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.9",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@storybook/addon-links": "^10.4.5",
    "@storybook/addon-onboarding": "^10.4.5",
    "@storybook/nextjs": "^10.4.5",
    "@storybook/react": "^10.4.5",
    "@storybook/test-runner": "^0.24.4",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/typography": "^0.5.20",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "contentful": "^11.12.5",
    "date-fns": "^4.4.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "framer-motion": "^12.40.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "lucide-react": "^1.18.0",
    "next": "^16.2.9",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rollup": "^4.62.0",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "storybook": "^10.4.6",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/yourusername"
  }
}
